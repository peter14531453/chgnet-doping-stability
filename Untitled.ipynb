   "source": [
    "import time, datetime\n",
    "\n",
    "i = 0\n",
    "while True:\n",
    "    i += 1\n",
    "    print(f\"[keepalive] {datetime.datetime.now():%Y-%m-%d %H:%M:%S}  tick {i}\", flush=True)\n",
    "    time.sleep(60)   # one heartbeat per minute, near-zero CPU\n"
   ]
